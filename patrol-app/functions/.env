# mock end-to-end, no external calls
MOCK_PAYMENTS=1
FUNCTIONS_EMULATOR=true

# URLs (for real mode these can be your actual app endpoints)
SUCCESS_URL=http://localhost:5173/success
CANCEL_URL=http://localhost:5173/cancel
WEBHOOK_URL=http://127.0.0.1:5005/makhi-cctv/us-central1/paymentWebhook

# Keep placeholders for when you flip to real mode
RELOADLY_CLIENT_ID=your_id_here
RELOADLY_CLIENT_SECRET=your_secret_here
OZOW_SITE_CODE=your_site_code
OZOW_PRIVATE_KEY=your_private_key
OZOW_API_URL=https://api.ozow.com  # ok to leave this; dotenv ignores the inline comment
