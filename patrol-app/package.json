{
  "name": "patrol-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:functions": "npm --prefix functions run build",
    "emulators:functions": "npm run build:functions && firebase emulators:start --only functions",
    "deploy:functions": "npm run build:functions && firebase deploy --only functions"
  },
  "dependencies": {
    "firebase": "^12.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.0",
    "firebase-tools": "^13.31.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.10"
  }
}
